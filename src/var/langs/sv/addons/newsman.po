msgid "Export Authorization"
msgstr "Exportauktorisering"

msgctxt "Languages::newsman.export_auth_header_name"
msgid "Header Name"
msgstr "Rubriknamn"

msgctxt "Languages::newsman.export_auth_header_name_help"
msgid "Authorization in HTTP header as name. Format alphanumeric separated by hyphen-minus. Please also set it in Newsman App > E-Commerce > Coupons > Authorisation Header name, Newsman App > E-Commerce > Feed > a feed > Header Authorization, etc."
msgstr "Auktorisering i HTTP-rubrik som namn. Alfanumeriskt format separerat med bindestreck. Ange det även i Newsman App > E-Commerce > Coupons > Authorisation Header name, Newsman App > E-Commerce > Feed > ett flöde > Header Authorization osv."

msgctxt "Languages::newsman.export_auth_header_key"
msgid "Header Key"
msgstr "Rubrikvärde"

msgctxt "Languages::newsman.export_auth_header_key_help"
msgid "Authorization in HTTP header as value. Format alphanumeric separated by hyphen-minus. Please also set it in Newsman App > E-Commerce > Coupons > Authorisation Header value, Newsman App > E-Commerce > Feed > a feed > Header Authorization, etc."
msgstr "Auktorisering i HTTP-rubrik som värde. Alfanumeriskt format separerat med bindestreck. Ange det även i Newsman App > E-Commerce > Coupons > Authorisation Header value, Newsman App > E-Commerce > Feed > ett flöde > Header Authorization osv."

msgctxt "Languages::newsman.authenticate_token"
msgid "Authentication Token"
msgstr "Autentiseringstoken"

msgctxt "Languages::newsman.authenticate_token_help"
msgid "Used for Newsman API authentication. It is exchanged automatically when the API key, User ID or list is changed, and when reconfigure or login with Newsman is done."
msgstr "Används för Newsman API-autentisering. Den byts ut automatiskt när API-nyckeln, användar-ID:t eller listan ändras, och vid omkonfigurering eller inloggning med Newsman."

msgctxt "Languages::newsman.token_not_set"
