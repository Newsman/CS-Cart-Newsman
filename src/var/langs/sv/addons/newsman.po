msgctxt "Languages::newsman.cscart_mailing_list_id_help"
msgid "Two-way sync is restricted to this mailing list: only its subscribers are pushed to Newsman, and Newsman webhooks affect only this list."
msgstr "Tvåvägssynkronisering är begränsad till denna sändlista: endast dess prenumeranter skickas till Newsman, och Newsman-webhooks påverkar endast denna lista."

msgctxt "Languages::newsman.cscart_mailing_list_id_warning"
msgid "Subscribe and unsubscribe will not work until a mailing list is selected here."
msgstr "Prenumeration och avprenumeration fungerar inte förrän en sändlista har valts här."

msgctxt "Languages::newsman.cscart_mailing_list_none"
msgid "Any list (no restriction)"
msgstr "Vilken lista som helst (ingen begränsning)"

